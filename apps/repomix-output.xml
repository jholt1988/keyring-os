'use client'
import type { FeedItem, UserRole } from '@keyring/types';
import { FeedCard } from './feed-card';
import { useCoPilotFeed } from '@/app/hooks/useCoPilotFeed';

type FeedListProps = {

  role: UserRole;
};

export function FeedList({ role: _role }: FeedListProps) {
  const { data: feedItems, isLoading, error } = useCoPilotFeed();

  if (isLoading) return <div className="skeleton w-full h-32 rounded-xl"></div>;
  if (error) return <div className="text-error">Failed to load intelligence feed.</div>;
  if (!feedItems?.length) return <div className="text-muted">No pending actions. You're caught up.</div>;

  if (feedItems.length === 0) {
    return (
      <p className="py-12 text-center text-sm text-muted-foreground">
        No items require your attention right now.
      </p>
    );
  }

  return (
    <div className="space-y-3">
      {feedItems.map((item) => (
        // priority is pre-computed by the backend — pass it directly
        <FeedCard key={item.id} item={item} score={item.priority} />
      ))}
    </div>
  );
}
